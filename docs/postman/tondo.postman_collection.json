                ],
                "body": { "mode": "raw", "raw": "{\n  \"sexe\": \"homme\",\n  \"adresse\": \"Libreville, Akanda\",\n  \"email\": \"daniel.doviakon@gmail.com\"\n}" },
                "url": { "raw": "{{base_url}}/api/mobile/profil", "host": ["{{base_url}}"], "path": ["api", "mobile", "profil"] }
              }
            }
          ]
        },
        {
          "name": "Cagnottes",
          "item": [
            {
              "name": "GET /api/mobile/cagnottes",
              "description": "Liste les cagnottes dont l'user est gérant. Filtres : ?statut=active|cloturee, ?type=tontine_periodique|cagnotte_ouverte.",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{mobile_token}}" }
                ],
                "url": { "raw": "{{base_url}}/api/mobile/cagnottes", "host": ["{{base_url}}"], "path": ["api", "mobile", "cagnottes"] }
              }
            },
            {
              "name": "POST /api/mobile/cagnottes (tontine périodique)",
              "description": "Crée une tontine. Génère une référence numérique 4-5 chiffres unique. Le numéro de retrait est masqué et IMMUTABLE après création.",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "  pm.collectionVariables.set('cagnotte_ref', pm.response.json().cagnotte.reference);",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{mobile_token}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"type\": \"tontine_periodique\",\n  \"titre\": \"Tontine bureau\",\n  \"numero_retrait\": \"+24177123456\",\n  \"montant_par_cycle\": 50000,\n  \"periodicite\": \"mensuelle\",\n  \"jour_mois\": 15,\n  \"nombre_participants\": 5\n}"
                },
                "url": { "raw": "{{base_url}}/api/mobile/cagnottes", "host": ["{{base_url}}"], "path": ["api", "mobile", "cagnottes"] }
              }
            },
            {
              "name": "POST /api/mobile/cagnottes (cagnotte ouverte)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Accept", "value": "application/json" },
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{mobile_token}}" }
                ],
                "body": {
                  "mode": "raw",
