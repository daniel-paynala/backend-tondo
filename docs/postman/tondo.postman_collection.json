                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Status 200', () => pm.response.to.have.status(200));",
                      "const data = pm.response.json();",
                      "pm.test('Token reçu', () => pm.expect(data.token).to.be.a('string'));",
                      "pm.collectionVariables.set('admin_token', data.token);",
